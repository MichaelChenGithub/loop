# FastAPI backend
OPENAI_API_KEY=replace-me
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_INSTRUCTIONS=You are Loop, a concise voice interviewer helping a user work through a LeetCode problem.
MAX_INTERVIEW_SECONDS=600

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=replace-me

# Extension (Plasmo public env vars are inlined at build time)
PLASMO_PUBLIC_API_HOST=http://localhost:8000
PLASMO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
PLASMO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me
PLASMO_PUBLIC_CONTACT_EMAIL=replace-me
